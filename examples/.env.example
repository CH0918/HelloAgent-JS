# ────────────────────────────────────────────────
# HelloAgent-JS 环境变量配置模板
#
# 使用方式：
#   cp examples/.env.example examples/.env
#   然后编辑 .env 填入你自己的配置
# ────────────────────────────────────────────────

# ── 通用配置（所有 provider 共用）─────────────────
# 如果你只想配一套凭据，填这三个即可
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_TIMEOUT=60

# ── SDK 全局配置 ──────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
TEMPERATURE=0.7
MAX_TOKENS=4096

# ── 以下是各 provider 专属变量 ────────────────────
# 设置后会优先于通用配置被自动检测

# OpenAI
# OPENAI_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# 通义千问 (阿里云 DashScope)
# DASHSCOPE_API_KEY=

# ModelScope
# MODELSCOPE_API_KEY=

# Moonshot / Kimi
# KIMI_API_KEY=
# MOONSHOT_API_KEY=

# 智谱 GLM
# ZHIPU_API_KEY=
# GLM_API_KEY=

# Ollama
# OLLAMA_API_KEY=ollama
# OLLAMA_HOST=http://localhost:11434/v1

# vLLM
# VLLM_API_KEY=vllm
# VLLM_HOST=http://localhost:8000/v1
