# ────────────────────────────────────────────────
# HelloAgent-JS 环境变量配置模板
#
# 使用方式：
#   cp examples/.env.example examples/.env
#   然后编辑 .env 填入你自己的配置
# ────────────────────────────────────────────────

# ── 通用配置（所有 provider 共用）─────────────────
# 如果你只想配一套凭据，填这三个即可
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL_ID=
LLM_TIMEOUT=60

# ── SDK 全局配置 ──────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
TEMPERATURE=0.7
MAX_TOKENS=4096

# ── 以下是各 provider 专属变量 ────────────────────
# 设置后会优先于通用配置被自动检测

# OpenAI
# OPENAI_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# 通义千问 (阿里云 DashScope)
# DASHSCOPE_API_KEY=

# ModelScope
# MODELSCOPE_API_KEY=

# Moonshot / Kimi
# KIMI_API_KEY=
# MOONSHOT_API_KEY=

# 智谱 GLM
# ZHIPU_API_KEY=
# GLM_API_KEY=

# Ollama
# OLLAMA_API_KEY=ollama
# OLLAMA_HOST=http://localhost:11434/v1

# vLLM
# VLLM_API_KEY=vllm
# VLLM_HOST=http://localhost:8000/v1

# ── 内置 SearchTool 搜索工具 ──────────────────────
# 默认组合模式。可选：hybrid、advanced、tavily、serpapi、duckduckgo、searxng、perplexity
SEARCH_BACKEND=hybrid

# Tavily
TAVILY_API_KEY=
# TAVILY_SEARCH_DEPTH=basic

# SerpApi
# SERPAPI_API_KEY=
# SERPAPI_GL=cn
# SERPAPI_HL=zh-cn

# SearXNG
# SEARXNG_URL=http://localhost:8888
# SEARXNG_LANGUAGE=zh-CN

# Perplexity
# PERPLEXITY_API_KEY=
# PERPLEXITY_ENDPOINT=https://api.perplexity.ai/v1/sonar
# PERPLEXITY_MODEL=

# ── 完整记忆系统：向量库 / 图数据库 / Embedding ───
# Embedding 模型。可选：openai_compatible、openrouter、dashscope、local、sentence_transformer、huggingface、tfidf
# 本地快速验证建议用 tfidf，不需要 API Key；真实语义检索建议用 OpenAI-compatible 远程服务或 local。
EMBED_MODEL_TYPE=tfidf
EMBED_MODEL_NAME=
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_DIMENSION=384

# OpenRouter embedding 示例：
# EMBED_MODEL_TYPE=openrouter
# EMBED_MODEL_NAME=openai/text-embedding-3-small
# EMBED_API_KEY=
# EMBED_BASE_URL=https://openrouter.ai/api/v1
# EMBED_DIMENSION=1536

# DashScope embedding 示例：
# EMBED_MODEL_TYPE=dashscope
# EMBED_MODEL_NAME=text-embedding-v3
# EMBED_API_KEY=
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBED_DIMENSION=1024

# Qdrant 向量数据库。
# 本地 Docker 默认不需要 QDRANT_API_KEY；Qdrant Cloud 需要填写。
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors
# 不填时默认跟随 EMBED_DIMENSION；两者都不填时默认 384。
QDRANT_VECTOR_SIZE=
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30
QDRANT_SEARCH_EF=128
QDRANT_SEARCH_EXACT=false

# Neo4j 图数据库。
# 下面的默认值对应示例里的本地 Docker：
#   docker run -p 7474:7474 -p 7687:7687 -e NEO4J_AUTH=neo4j/hello-agents-password neo4j:5
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
# NEO4J_USER=neo4j
NEO4J_PASSWORD=hello-agents-password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60
